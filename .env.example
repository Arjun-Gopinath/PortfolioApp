# Set to "true" to show the "Open to Work" badge on the hero section.
# Also set this in your Vercel dashboard under Project > Settings > Environment Variables.
VITE_OPEN_TO_WORK=false

# OpenRouter API key for the chat feature (server-side only, no VITE_ prefix)
OPENROUTER_API_KEY=

# Comma-separated list of allowed origins for the /api/chat endpoint.
# Add your production URL here to block requests from other domains.
# Example: ALLOWED_ORIGIN=https://arjungopinath.dev
# Localhost is always allowed automatically.
ALLOWED_ORIGIN=
